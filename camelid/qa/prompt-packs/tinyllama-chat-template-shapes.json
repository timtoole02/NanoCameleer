{
  "schema": "camelid.tinyllama.prompt-pack.v1",
  "pack_id": "tinyllama-chat-template-shapes-v1",
  "description": "Bounded TinyLlama marker-template shape coverage for the exact TinyLlama Q8_0 row. These cases exercise Camelid's explicit marker renderer rather than broader LLaMA-family claims.",
  "defaults": {
    "max_tokens": 5,
    "render_mode": "tinyllama-marker"
  },
  "prompts": [
    {
      "id": "single-system-user",
      "note": "System + user message shape.",
      "messages": [
        { "role": "system", "content": "Answer briefly and stay factual." },
        { "role": "user", "content": "Name one primary color." }
      ]
    },
    {
      "id": "multi-turn-user-assistant-user",
      "note": "Multi-turn user/assistant history followed by a new user turn.",
      "messages": [
        { "role": "user", "content": "Say alpha." },
        { "role": "assistant", "content": "alpha" },
        { "role": "user", "content": "Now say beta." }
      ]
    },
    {
      "id": "assistant-final-no-generation-header",
      "note": "Assistant-final messages should not append another assistant generation header.",
      "messages": [
        { "role": "user", "content": "Complete the word: cam" },
        { "role": "assistant", "content": "elid" }
      ],
      "max_tokens": 1
    },
    {
      "id": "multiline-whitespace-preservation",
      "note": "Whitespace and multiline content are preserved inside message content.",
      "messages": [
        { "role": "system", "content": "Preserve line breaks in reasoning inputs." },
        { "role": "user", "content": "Line one.\n\n  Indented line two.  " }
      ]
    }
  ]
}
